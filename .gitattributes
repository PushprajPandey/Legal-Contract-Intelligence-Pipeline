# Normalize line endings to LF on all platforms
* text=auto eol=lf

# Force these to always be LF
*.py text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.csv text eol=lf
*.json text eol=lf
*.env text eol=lf

# Binary files — don't touch line endings
*.npz binary
*.pdf binary
*.png binary
*.jpg binary
