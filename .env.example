# ── Task 2 — LLM Extraction & Summarization ───────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

MODEL_NAME=qwen2.5:1.5b

EMBED_MODEL_NAME=nomic-embed-text

NUM_CTX=4096

CHUNK_SIZE_TOKENS=1500
CHUNK_OVERLAP_TOKENS=100

CHECKPOINT_EVERY=5

CLAUSE_MERGE_STRATEGY=longest

# ── Task 1 — Paths ─────────────────────────────────────────────────────────
# Set CUAD_BASE_PATH to wherever you downloaded and unzipped CUAD_v1
CUAD_BASE_PATH=/path/to/CUAD_v1

SELECTED_OUTPUT_DIR=/path/to/CUAD_v1/selected_50

PREPROCESSED_OUTPUT_PATH=/path/to/cuad_pipeline/contracts_preprocessed.json

# ── Task 1 — Sampling ──────────────────────────────────────────────────────
RANDOM_SEED=42
SAMPLE_SIZE=50
